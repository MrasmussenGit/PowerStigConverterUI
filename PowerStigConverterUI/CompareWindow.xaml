<Window x:Class="PowerStigConverterUI.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compare DISA vs PowerSTIG" Height="680" Width="1400"
        Background="{StaticResource BackgroundLightBrush}"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="ResultCountStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="ResultListStyle" TargetType="ListView">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="MinHeight" Value="18"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <TextBlock Text="Compare DISA vs PowerSTIG" Style="{StaticResource HeaderTitleStyle}"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.ColumnSpan="2"
                   Text="Select files and press Compare"
                   Style="{StaticResource SectionTitleStyle}"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,10">
            <TextBlock VerticalAlignment="Center" Text="DISA XCCDF or ZIP:" Margin="0,0,6,0" Style="{StaticResource LabelTextStyle}"/>
            <TextBox x:Name="DisaPathTextBox" Width="335" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
            <Button Content="Browse…" Style="{StaticResource StandardButtonStyle}" Width="84" Click="BrowseDisa_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock VerticalAlignment="Center" Text="PowerSTIG file:" Margin="0,0,6,0" Style="{StaticResource LabelTextStyle}"/>
            <TextBox x:Name="PsPathTextBox" Width="335" Margin="0,0,6,0" VerticalContentAlignment="Center"/>
            <Button Content="Browse…" Style="{StaticResource StandardButtonStyle}" Width="84" Click="BrowsePs_Click"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <!-- Equal width columns to fill the space -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Matched on the left -->
            <GroupBox Grid.Column="0" Header="Matched (common IDs)" Margin="0,0,3,0">
                <GroupBox.ToolTip>
                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">Matched Rules</Run>
                        <LineBreak/><LineBreak/>
                        Rules successfully converted and present in both the DISA STIG and PowerSTIG output. These rules will be automatically applied when you compile your MOF file using this DSC resource.
                    </TextBlock>
                </GroupBox.ToolTip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MatchedCountTextBlock" Style="{StaticResource ResultCountStyle}"/>
                    <ListView x:Name="MatchedListView"
                              Grid.Row="1"
                              Style="{StaticResource ResultListStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="MatchedListView_MouseDoubleClick"/>
                </Grid>
            </GroupBox>

            <!-- Skipped (new column) -->
            <GroupBox Grid.Column="1" Header="Skipped (in log file)" Margin="3,0,3,0">
                <GroupBox.ToolTip>
                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">Skipped Rules</Run>
                        <LineBreak/><LineBreak/>
                        Rules that encountered errors during conversion and were added to the log file. These rules are marked as "skipped" in the converted XML and will NOT be processed or applied when creating MOF files. Review the conversion report or log file for details on why these rules failed.
                    </TextBlock>
                </GroupBox.ToolTip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SkippedCountTextBlock" Style="{StaticResource ResultCountStyle}"/>
                    <ListView x:Name="SkippedListView"
                              Grid.Row="1"
                              Style="{StaticResource ResultListStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="SkippedListView_MouseDoubleClick"/>
                </Grid>
            </GroupBox>

            <!-- Missing -->
            <GroupBox Grid.Column="2" Header="Missing (in PowerSTIG)" Margin="3,0,3,0">
                <GroupBox.ToolTip>
                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">Missing Rules</Run>
                        <LineBreak/><LineBreak/>
                        Rules present in the DISA STIG but completely absent from the PowerSTIG converted output. This indicates a conversion problem that requires investigation. Missing rules will not be available for enforcement in your DSC configuration.
                    </TextBlock>
                </GroupBox.ToolTip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MissingCountTextBlock" Style="{StaticResource ResultCountStyle}"/>
                    <ListView x:Name="MissingListView"
                              Grid.Row="1"
                              Style="{StaticResource ResultListStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="MissingListView_MouseDoubleClick"/>
                </Grid>
            </GroupBox>

            <!-- Added on the right -->
            <GroupBox Grid.Column="3" Header="Added (extra in PowerSTIG)" Margin="3,0,0,0">
                <GroupBox.ToolTip>
                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                        <Run FontWeight="SemiBold">Added Rule Variants</Run>
                        <LineBreak/><LineBreak/>
                        Additional rule variants (V-12345.a, V-12345.b, V-12345.c, etc.) created by PowerSTIG when a single DISA rule requires multiple distinct checks or configurations. These variants share the same V-ID as the base rule but implement different aspects of the original requirement. All variants will be applied during MOF compilation.
                    </TextBlock>
                </GroupBox.ToolTip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="AddedCountTextBlock" Style="{StaticResource ResultCountStyle}"/>
                    <ListView x:Name="AddedListView"
                              Grid.Row="1"
                              Style="{StaticResource ResultListStyle}"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              MouseDoubleClick="AddedListView_MouseDoubleClick"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Bottom bar: Info left, Actions right -->
        <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Info text (left aligned) -->
            <TextBlock x:Name="InfoTextBlock" Grid.Column="0" VerticalAlignment="Center" FontSize="12"/>

            <!-- Actions (right aligned) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Compare" Style="{StaticResource PrimaryButtonStyle}" Width="110" Margin="0,0,8,0" Click="Compare_Click"/>
                <Button Content="Close" Style="{StaticResource SecondaryButtonStyle}" Width="84" IsCancel="True"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</Window>
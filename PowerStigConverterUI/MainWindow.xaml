<Window x:Class="PowerStigConverterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerStig Converter UI" Height="460" Width="400"
        Background="{StaticResource BackgroundLightBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <TextBlock Text="PowerStig Converter" Style="{StaticResource HeaderTitleStyle}"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Centered and stacked buttons -->
            <StackPanel Orientation="Vertical"
                        Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="ConvertStigButton"
                        Content="Convert STIG"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="ConvertStigButton_Click"/>
                <Button x:Name="CompareButton"
                        Content="Compare"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="CompareButton_Click"/>
                <Button x:Name="SplitStigButton"
                        Content="Split OS STIG"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="SplitOsStigButton_Click"/>
                <Button x:Name="ExitButton"
                        Content="Exit"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="ExitButton_Click"/>
            </StackPanel>

            <!-- Version Info -->
            <TextBlock x:Name="VersionTextBlock"
                       Grid.Row="1"
                       Text="Version"
                       Style="{StaticResource SmallTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>
        </Grid>
    </Grid>
</Window>

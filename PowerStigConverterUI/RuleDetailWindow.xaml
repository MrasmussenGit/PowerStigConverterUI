<Window x:Class="PowerStigConverterUI.RuleDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rule Details" Height="550" Width="720"
        Background="{StaticResource BackgroundLightBrush}"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <TextBlock x:Name="RuleIdTextBlock" Style="{StaticResource HeaderTitleStyle}"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="DetailsTextBlock" TextWrapping="Wrap" Style="{StaticResource BodyTextStyle}"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
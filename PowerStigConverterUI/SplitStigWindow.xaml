<Window x:Class="PowerStigConverterUI.SplitStigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Windows OS STIG into MS/DC variants" Height="500" Width="900"
        Background="{StaticResource BackgroundLightBrush}"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <TextBlock Text="Split Windows OS STIG" Style="{StaticResource HeaderTitleStyle}"/>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15" Grid.IsSharedSizeScope="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Advanced: Module selection (collapsed by default) -->
        <Expander x:Name="ModuleExpander" Grid.Row="0" IsExpanded="False" Header="Advanced (PowerSTIG module)" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Functions file:" Style="{StaticResource LabelTextStyle}"/>
                <TextBox x:Name="ModulePathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,0" MinWidth="500" VerticalContentAlignment="Center"/>
                <Button Grid.Row="0" Grid.Column="2" Content="Change..." Style="{StaticResource StandardButtonStyle}" Click="BrowseModule_Click"/>

                <!-- Warning text (initially collapsed) -->
                <TextBlock x:Name="ModuleWarningText" 
                           Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                           Margin="0,8,0,0" 
                           Foreground="#D32F2F" 
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           Text="⚠ PowerSTIG Functions.XccdfXml.ps1 file not found. Please browse to the file location or install PowerSTIG module."/>
            </Grid>
        </Expander>

        <!-- Source file selection -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="DISA STIG XML or ZIP:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource LabelTextStyle}"/>
            <TextBox x:Name="SourcePathTextBox" Grid.Column="1" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse…" Style="{StaticResource StandardButtonStyle}" Width="90" Click="Browse_Click"/>
        </Grid>

        <!-- Destination folder selection -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Destination folder:" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource LabelTextStyle}"/>
            <TextBox x:Name="DestinationPathTextBox" Grid.Column="1" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
            <Button x:Name="DestinationBrowseButton" Grid.Column="2" Content="Browse…" Style="{StaticResource StandardButtonStyle}" Width="90" Click="DestinationBrowse_Click"/>
        </Grid>

        <!-- Options -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="OverwriteCheckBox" Content="Overwrite if files exist" IsChecked="True"/>
        </StackPanel>

        <!-- Output / Messages -->
        <GroupBox Grid.Row="4">
            <GroupBox.Header>
                <TextBlock Text="Messages" FontWeight="SemiBold"/>
            </GroupBox.Header>
            <RichTextBox x:Name="OutputRichTextBox"
                         Margin="8"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"
                         Background="White">
                <RichTextBox.Document>
                    <FlowDocument/>
                </RichTextBox.Document>
            </RichTextBox>
        </GroupBox>

        <!-- Bottom bar: Status and Actions stacked vertically -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Status text (full width, top row) - TextBox for copyable text -->
            <TextBox x:Name="StatusText" 
                     Grid.Row="0" 
                     IsReadOnly="True" 
                     IsReadOnlyCaretVisible="False"
                     Background="Transparent" 
                     BorderThickness="0"
                     TextWrapping="Wrap" 
                     Margin="0,0,0,8"
                     Focusable="True"
                     IsTabStop="False"/>

            <!-- Actions (right aligned, bottom row) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Clear button (left aligned) -->
                <Button x:Name="ClearMessagesButton" 
                        Grid.Column="0"
                        Content="Clear" 
                        Style="{StaticResource StandardButtonStyle}" 
                        Width="100" 
                        HorizontalAlignment="Left"
                        Click="ClearMessages_Click"/>

                <!-- Actions (right aligned) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SplitButton" Content="Split" Style="{StaticResource PrimaryButtonStyle}" Width="100" Margin="0,0,8,0" Click="SplitButton_Click"/>
                    <Button x:Name="CloseButton" Content="Close" Style="{StaticResource SecondaryButtonStyle}" Width="90" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
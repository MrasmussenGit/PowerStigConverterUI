<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Import Colors -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <!-- BADGE/CHIP STYLES -->
    <!-- Used for status indicators, severity levels, counts, etc. -->
    
    <!-- Base Badge Style -->
    <Style x:Key="BaseBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Margin" Value="5,2"/>
    </Style>
    
    <!-- Success Badge (Green) -->
    <Style x:Key="SuccessBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusSuccessBrush}"/>
    </Style>
    
    <!-- Warning Badge (Orange) -->
    <Style x:Key="WarningBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
    </Style>
    
    <!-- Error Badge (Red) -->
    <Style x:Key="ErrorBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusErrorBrush}"/>
    </Style>
    
    <!-- Info Badge (Blue) -->
    <Style x:Key="InfoBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusInfoBrush}"/>
    </Style>
    
    <!-- Purple Badge (for coverage percentages) -->
    <Style x:Key="CoverageBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusPurpleBrush}"/>
    </Style>
    
    <!-- Teal Badge (for automation percentages) -->
    <Style x:Key="AutomationBadgeStyle" TargetType="Border" BasedOn="{StaticResource BaseBadgeStyle}">
        <Setter Property="Background" Value="{StaticResource StatusTealBrush}"/>
    </Style>
    
    <!-- Badge Text Style (white, bold) -->
    <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    
    <!-- SUMMARY BOX STYLES (Clickable statistic boxes) -->
    
    <!-- Summary Box Base -->
    <Style x:Key="SummaryBoxStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>
    
    <!-- Summary Box - Info (Blue) -->
    <Style x:Key="SummaryBoxInfoStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusInfoBrush}"/>
    </Style>
    
    <!-- Summary Box - Success (Green) -->
    <Style x:Key="SummaryBoxSuccessStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusSuccessBrush}"/>
    </Style>
    
    <!-- Summary Box - Warning (Orange) -->
    <Style x:Key="SummaryBoxWarningStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusWarningBrush}"/>
    </Style>
    
    <!-- Summary Box - Error (Red) -->
    <Style x:Key="SummaryBoxErrorStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusErrorBrush}"/>
    </Style>
    
    <!-- Summary Box - Purple -->
    <Style x:Key="SummaryBoxPurpleStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusPurpleBrush}"/>
    </Style>
    
    <!-- Summary Box - Teal -->
    <Style x:Key="SummaryBoxTealStyle" TargetType="Border" BasedOn="{StaticResource SummaryBoxStyle}">
        <Setter Property="Background" Value="{StaticResource StatusTealBrush}"/>
    </Style>
    
    <!-- Summary Number Text (large, bold, white) -->
    <Style x:Key="SummaryNumberStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    
    <!-- Summary Label Text (small, white) -->
    <Style x:Key="SummaryLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>
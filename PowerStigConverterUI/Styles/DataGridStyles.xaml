<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Import Colors -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>
    
    <!-- DATAGRID STYLES -->
    
    <!-- DataGrid Column Header Style -->
    <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Background" Value="#34495E"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <!-- DataGrid Standard Style -->
    <Style x:Key="StandardDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserReorderColumns" Value="False"/>
        <Setter Property="CanUserSortColumns" Value="True"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="RowHeight" Value="34"/>
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGridHeaderStyle}"/>
    </Style>
    
    <!-- DataGrid Cell Text Style (standard padding) -->
    <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    
    <!-- DataGrid Cell Text Style (centered) -->
    <Style x:Key="DataGridCellTextCenteredStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>
    
    <!-- DataGrid Cell Text Style (bold) -->
    <Style x:Key="DataGridCellTextBoldStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
</ResourceDictionary>